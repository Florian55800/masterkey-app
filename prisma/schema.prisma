datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  pin       String
  color     String
  photo     String?
  role      String   @default("")
  createdAt DateTime @default(now())
  teamGoals TeamGoal[]
}

model Owner {
  id             Int                 @id @default(autoincrement())
  name           String
  phone          String?
  email          String?
  notes          String?
  photo          String?
  lastContact    DateTime?
  relanceDate    DateTime?
  relanceNote    String?
  source         String?
  properties     Property[]
  satisfactions  SatisfactionScore[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model Staff {
  id         Int        @id @default(autoincrement())
  name       String
  phone      String?
  email      String?
  role       String     @default("ménage")
  notes      String?
  photo      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  properties Property[]
}

model Property {
  id             Int               @id @default(autoincrement())
  name           String
  address        String
  city           String
  type           String
  typeGestion    String            @default("conciergerie")
  ownerId        Int
  owner          Owner             @relation(fields: [ownerId], references: [id])
  commissionRate Float
  cleaningFee    Float             @default(0)
  staffId        Int?
  staff          Staff?            @relation(fields: [staffId], references: [id], onDelete: SetNull)
  photo          String?
  description    String?
  dateSigned     DateTime
  dateLost       DateTime?
  status         String            @default("active")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  revenues       PropertyRevenue[]
  subletExpenses SubletExpense[]
}

model PropertyRevenue {
  id             Int      @id @default(autoincrement())
  propertyId     Int
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  month          Int
  year           Int
  platform       String   // "airbnb" | "booking" | "direct" | "autre"
  platformAmount Float    @default(0)
  cleaningFees   Float    @default(0)
  commissionRate Float    @default(0)
  notes          String?
  nbSejours      Int      @default(0)
  nbNuits        Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@unique([propertyId, month, year, platform])
}

model SubletExpense {
  id            Int      @id @default(autoincrement())
  propertyId    Int
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  month         Int
  year          Int
  loyer         Float    @default(0)
  electricite   Float    @default(0)
  wifi          Float    @default(0)
  autresCharges Float    @default(0)
  nbSejours     Int      @default(0)
  nbNuits       Int      @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@unique([propertyId, month, year])
}

model SatisfactionScore {
  id        Int      @id @default(autoincrement())
  ownerId   Int
  owner     Owner    @relation(fields: [ownerId], references: [id])
  score     Int
  quarter   Int
  year      Int
  createdAt DateTime @default(now())
}

model MonthlyReport {
  id               Int       @id @default(autoincrement())
  month            Int
  year             Int
  caBrut           Float     @default(0)
  commissions      Float     @default(0)
  activeProperties Int       @default(0)
  totalNights      Int       @default(0)
  newSignatures    Int       @default(0)
  lostProperties   Int       @default(0)
  netProfit        Float     @default(0)
  notes            String?
  targetMargin     Float?
  isPlaceholder    Boolean   @default(false)
  expenses         Expense[]
  teamGoals        TeamGoal[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  @@unique([month, year])
}

model Expense {
  id          Int           @id @default(autoincrement())
  reportId    Int
  report      MonthlyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  category    String
  description String?
  amount      Float
  isRecurring Boolean       @default(false)
  createdAt   DateTime      @default(now())
}

model TeamGoal {
  id               Int           @id @default(autoincrement())
  userId           Int
  user             User          @relation(fields: [userId], references: [id])
  reportId         Int
  report           MonthlyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  propertiesSigned Int           @default(0)
  appointmentsMade Int           @default(0)
  personalGoal     String?
  goalStatus       String        @default("en_cours")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  @@unique([userId, reportId])
}

model MonthlyObjective {
  id                  Int      @id @default(autoincrement())
  month               Int      // 0 = objectif annuel
  year                Int
  targetLeads         Int      @default(0)
  targetSignatures    Int      @default(0)
  targetVisites       Int      @default(0)
  targetAppels        Int      @default(0)
  targetCAParLogement Float    @default(0)
  targetLogements     Int      @default(0)
  actualLeads         Int      @default(0)
  actualSignatures    Int      @default(0)
  actualVisites       Int      @default(0)
  actualAppels        Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  @@unique([month, year])
}

model City {
  id       Int     @id @default(autoincrement())
  name     String  @unique
  isActive Boolean @default(false)
}

model Config {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Lead {
  id           Int       @id @default(autoincrement())
  nom          String
  email        String?
  telephone    String?
  adresseBien  String?
  ville        String?
  typeBien     String?
  nbChambres   String?
  surface      Float?
  lienAnnonce  String?
  statut       String    @default("À contacter")
  commentaires String?
  dateContact  DateTime  @default(now())
  relanceDate  DateTime?
  relanceNote  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  visits       Visit[]
}

model Visit {
  id        Int      @id @default(autoincrement())
  leadId    Int?
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  date      DateTime
  address   String
  notes     String?
  createdAt DateTime @default(now())
}

model Task {
  id        Int      @id @default(autoincrement())
  title     String
  type      String   @default("autre")
  month     Int
  year      Int
  createdAt DateTime @default(now())
}
